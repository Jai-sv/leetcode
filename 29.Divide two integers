import math
class Solution(object):
    def divide(self, dividend, divisor):
        """
        :type dividend: int
        :type divisor: int
        :rtype: int
        """
        if dividend == -2**31 and divisor == -1:
            return 2**31 - 1
        n=(dividend<0) != (divisor<0)
        dividend=abs(dividend)
        divisor=abs(divisor)
        r=int(dividend/divisor)
        if n:
            return -r
        else:
            return r

        
